<!-- ── CTA BANNER ─────────────────────────────────────────────────── -->
<section style="background:linear-gradient(135deg,var(--gold),var(--amber));padding:80px 5%;text-align:center;">
  <div class="reveal">
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,3rem);color:var(--deep);margin-bottom:16px;">Ready to Explore the World?</h2>
