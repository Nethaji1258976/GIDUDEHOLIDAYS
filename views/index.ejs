    </div>

    <div class="dest-card reveal">
      <img src="https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=700&q=80" alt="Bali" loading="lazy" />
      <div class="dest-overlay">
        <div class="dest-country">Indonesia</div>
        <div class="dest-name">Bali</div>
        <div class="dest-meta">
          <span class="dest-tag">Beaches</span>
          <span class="dest-tag">Temples</span>
        </div>
        <a href="/destinations#bali" class="dest-btn">Explore ›</a>
      </div>
    </div>

    <div class="dest-card reveal">
      <img src="https://images.unsplash.com/photo-1506665531195-3566af2b4dfa?w=700&q=80" alt="Thailand" loading="lazy" />
      <div class="dest-overlay">
        <div class="dest-country">Southeast Asia</div>
        <div class="dest-name">Thailand</div>
        <div class="dest-meta">
          <span class="dest-tag">Beaches</span>
          <span class="dest-tag">Culture</span>
        </div>
        <a href="/destinations#thailand" class="dest-btn">Explore ›</a>
      </div>
    </div>

    <div class="dest-card reveal">
      <img src="https://images.unsplash.com/photo-1555921015-5532091f6026?w=700&q=80" alt="Vietnam" loading="lazy" />
      <div class="dest-overlay">
        <div class="dest-country">Southeast Asia</div>
        <div class="dest-name">Vietnam</div>
        <div class="dest-meta">
          <span class="dest-tag">History</span>
          <span class="dest-tag">Scenic</span>
        </div>
        <a href="/destinations#vietnam" class="dest-btn">Explore ›</a>
      </div>
    </div>

    <div class="dest-card reveal" style="background:linear-gradient(135deg,var(--ocean),var(--deep));display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;padding:40px;text-align:center;">
      <div style="font-size:3rem;">✈</div>
      <h3 style="color:var(--white);font-family:'Playfair Display',serif;">Custom Package?</h3>
      <p style="color:rgba(255,255,255,0.7);font-size:14px;">Tell us your dream destination and we'll craft a perfect itinerary.</p>
      <a href="/contact" class="btn btn-primary" style="margin-top:8px">Enquire Now</a>
    </div>
  </div>
</section>

<!-- ── SERVICES ──────────────────────────────────────────────────── -->
<section class="section services-bg">
