<%- include('partials/header', { pageTitle: 'Home', activePage: 'home' }) %>

<!-- ── HERO ──────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-particles" id="particles"></div>
  <div class="hero-content">
    <div class="hero-badge">Premium B2B Travel Partner</div>
    <h1 class="hero-title">
      Discover the World,<br>
      <span class="highlight">One Journey</span> at a Time
    </h1>
    <p class="hero-desc">
      GoDude Holidays offers curated travel packages across Southeast Asia for travel agents,
      tour operators, and holidaymakers. Transparent pricing. Trusted service.
    </p>
    <div class="hero-actions">
      <a href="#quote" class="btn btn-primary">✈ Get a Free Quote</a>
      <a href="/destinations" class="btn btn-outline">🌍 View Destinations</a>
    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num" data-target="500" data-suffix="+">0+</div>
        <div class="stat-label">Happy Travellers</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="15" data-suffix="+">0+</div>
        <div class="stat-label">Destinations</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="5" data-suffix=" Yrs">0</div>
        <div class="stat-label">Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="100" data-suffix="%">0%</div>
        <div class="stat-label">Satisfaction</div>
      </div>
    </div>
  </div>
</section>

<!-- ── QUICK QUOTE ─────────────────────────────────────────────── -->
<section class="quote-section" id="quote">
  <div class="quote-card reveal">
    <h3>✈ Get an Instant Quote</h3>
    <form class="quote-form" id="quoteForm">
      <div class="form-group">
        <label>Your Name</label>
        <input type="text" name="name" placeholder="Full name" required />
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" />
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="your@email.com" required />
      </div>
      <div class="form-group">
        <label>Destination</label>
        <select name="subject">
          <option value="">Select destination</option>
          <option>Singapore</option>
          <option>Malaysia</option>
          <option>Bali</option>
          <option>Thailand</option>
          <option>Vietnam</option>
          <option>Custom Package</option>
        </select>
      </div>
      <div class="form-group">
        <label>Message</label>
        <input type="text" name="message" placeholder="Travel dates, no. of persons..." />
      </div>
      <div class="form-group">
        <label>&nbsp;</label>
        <button type="submit" class="btn btn-primary" style="width:100%">🚀 Send Enquiry</button>
      </div>
    </form>
  </div>
</section>

<!-- ── DESTINATIONS ─────────────────────────────────────────────── -->
<section class="section">
  <div class="section-header reveal">
    <div class="section-tag">Our Destinations</div>
    <h2 class="section-title">Explore <span>Southeast Asia</span></h2>
    <p class="section-sub">Hand-picked destinations with curated packages, transparent pricing, and expert support.</p>
  </div>

  <div class="dest-grid">
    <div class="dest-card reveal">
      <img src="https://images.unsplash.com/photo-1525625293386-3f8f99389edd?w=700&q=80" alt="Singapore" loading="lazy" />
      <div class="dest-overlay">
        <div class="dest-country">Southeast Asia</div>
        <div class="dest-name">Singapore</div>
        <div class="dest-meta">
          <span class="dest-tag">City & Culture</span>
          <span class="dest-tag">Shopping</span>
        </div>
        <a href="/destinations#singapore" class="dest-btn">Explore ›</a>
      </div>
    </div>

    <div class="dest-card reveal">
      <img src="https://images.unsplash.com/photo-1596422846543-75c6fc197f07?w=700&q=80" alt="Malaysia" loading="lazy" />
      <div class="dest-overlay">
        <div class="dest-country">Southeast Asia</div>
        <div class="dest-name">Malaysia</div>
        <div class="dest-meta">
          <span class="dest-tag">Nature</span>
          <span class="dest-tag">Food</span>
        </div>
        <a href="/destinations#malaysia" class="dest-btn">Explore ›</a>
