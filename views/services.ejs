<%- include('partials/header', { pageTitle: 'Services', activePage: 'services' }) %>

<div class="page-hero">
  <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1920&q=80');"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <div class="section-tag">What We Do</div>
    <h1>Our Services</h1>
    <div class="breadcrumb"><a href="/">Home</a> › Services</div>
  </div>
</div>

<section class="section">
  <div style="max-width:1280px;margin:0 auto;">
    <div class="section-header center reveal">
      <div class="section-tag">End-to-End Travel Solutions</div>
      <h2 class="section-title">Everything You Need for a <span>Perfect Trip</span></h2>
      <p class="section-sub">From hotel booking to custom packages — GoDude Holidays handles it all with precision and care.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:32px;margin-top:60px;">
      <div class="reveal" style="background:var(--white);border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);border-top:4px solid var(--gold);">
        <div style="font-size:3rem;margin-bottom:20px;">🏨</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--ocean);margin-bottom:12px;">Hotel Booking</h3>
        <p style="color:var(--gray);line-height:1.7;margin-bottom:20px;">We partner with 500+ hotels across Southeast Asia to offer special agent rates. From budget stays to luxury resorts — instant confirmation, no hidden fees.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="color:var(--text);font-size:14px;">✅ Budget to Luxury options</li>
          <li style="color:var(--text);font-size:14px;">✅ Special B2B rates for agents</li>
          <li style="color:var(--text);font-size:14px;">✅ Breakfast / meal plans available</li>
          <li style="color:var(--text);font-size:14px;">✅ Instant confirmation</li>
        </ul>
      </div>

      <div class="reveal" style="background:var(--white);border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);border-top:4px solid var(--sky);">
        <div style="font-size:3rem;margin-bottom:20px;">🚌</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--ocean);margin-bottom:12px;">Transfers</h3>
        <p style="color:var(--gray);line-height:1.7;margin-bottom:20px;">Private and SIC (Seat-in-Coach) airport transfers, city-to-city connections, and intercity coaches — safe, reliable, and always on time.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="color:var(--text);font-size:14px;">✅ Private & SIC options</li>
          <li style="color:var(--text);font-size:14px;">✅ Airport pickups & drops</li>
          <li style="color:var(--text);font-size:14px;">✅ Professional drivers</li>
          <li style="color:var(--text);font-size:14px;">✅ AC vehicles (vans / coaches)</li>
        </ul>
      </div>

      <div class="reveal" style="background:var(--white);border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);border-top:4px solid var(--mint);">
        <div style="font-size:3rem;margin-bottom:20px;">🎭</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--ocean);margin-bottom:12px;">Sightseeing</h3>
        <p style="color:var(--gray);line-height:1.7;margin-bottom:20px;">Guided tours to top attractions, cultural experiences, theme parks, and nature trips — curated for every type of traveller.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="color:var(--text);font-size:14px;">✅ Full-day & half-day tours</li>
          <li style="color:var(--text);font-size:14px;">✅ English-speaking guides</li>
          <li style="color:var(--text);font-size:14px;">✅ Theme parks & attractions</li>
          <li style="color:var(--text);font-size:14px;">✅ Private & group options</li>
        </ul>
      </div>

      <div class="reveal" style="background:var(--white);border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);border-top:4px solid var(--coral);">
        <div style="font-size:3rem;margin-bottom:20px;">🎟</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--ocean);margin-bottom:12px;">Ticket Booking</h3>
        <p style="color:var(--gray);line-height:1.7;margin-bottom:20px;">Pre-book entry tickets to Universal Studios, Gardens by the Bay, Genting Highlands, Phi Phi islands, and 100+ other attractions.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="color:var(--text);font-size:14px;">✅ Skip-the-queue tickets</li>
          <li style="color:var(--text);font-size:14px;">✅ Theme parks & shows</li>
          <li style="color:var(--text);font-size:14px;">✅ Combo packages available</li>
          <li style="color:var(--text);font-size:14px;">✅ Instant e-tickets</li>
        </ul>
      </div>

      <div class="reveal" style="background:var(--white);border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);border-top:4px solid var(--amber);">
        <div style="font-size:3rem;margin-bottom:20px;">📦</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--ocean);margin-bottom:12px;">Custom Packages</h3>
        <p style="color:var(--gray);line-height:1.7;margin-bottom:20px;">Tell us your destination, group size, budget, and interests — we'll design a tailor-made itinerary that exceeds expectations.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="color:var(--text);font-size:14px;">✅ Fully customisable</li>
          <li style="color:var(--text);font-size:14px;">✅ Honeymoon, family, corporate</li>
          <li style="color:var(--text);font-size:14px;">✅ Downloadable itineraries</li>
          <li style="color:var(--text);font-size:14px;">✅ 2-hour quote turnaround</li>
        </ul>
      </div>

      <div class="reveal" style="background:linear-gradient(135deg,var(--ocean),var(--deep));border-radius:16px;padding:40px;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;gap:20px;">
        <div style="font-size:3rem;">🤝</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--white);">B2B Partner Program</h3>
        <p style="color:rgba(255,255,255,0.7);line-height:1.7;">Join as a travel agent and unlock special pricing, downloadable itineraries, and a dedicated support manager.</p>
        <a href="/b2b" class="btn btn-primary">Register as Agent</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
