<%- include('partials/header', { pageTitle: 'Contact', activePage: 'contact' }) %>

<div class="page-hero">
  <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1920&q=80');"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <div class="section-tag">Get In Touch</div>
    <h1>Contact Us</h1>
    <div class="breadcrumb"><a href="/">Home</a> › Contact</div>
  </div>
</div>

<section class="section">
  <div class="contact-wrap" style="max-width:1280px;margin:0 auto;">
    <div class="contact-info reveal">
      <div class="section-tag">Let's Talk</div>
      <h2 class="section-title">We're Here to <span>Help You</span></h2>
      <p class="section-sub">Have a question or need a custom travel package? Reach out and we'll respond within 2 hours.</p>

      <div style="margin-top:40px;">
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <h5>Phone / WhatsApp</h5>
            <p>+91 98765 43210</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📧</div>
          <div>
            <h5>Email</h5>
            <p>info@godudeholidays.com</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <h5>Office</h5>
            <p>Madurai, Tamil Nadu, India</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">🕐</div>
          <div>
            <h5>Working Hours</h5>
            <p>Mon–Sat: 9AM – 7PM IST</p>
          </div>
        </div>
      </div>

      <a href="https://wa.me/919876543210?text=Hi%20GoDude%20Holidays!" target="_blank" class="btn btn-primary" style="margin-top:24px;display:inline-flex;">💬 Chat on WhatsApp</a>
    </div>

    <div class="contact-form-card reveal">
      <h3 style="font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--ocean);margin-bottom:8px;">Send an Enquiry</h3>
      <p style="color:var(--gray);margin-bottom:28px;font-size:14px;">Fill in the form and we'll get back to you within 2 hours.</p>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">✅ Thank you! Your message has been received. We'll contact you soon.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">❌ <%= error %></div>
      <% } %>

      <form id="quoteForm" style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div class="form-group">
            <label>Full Name *</label>
            <input type="text" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" />
          </div>
        </div>
        <div class="form-group">
          <label>Email Address *</label>
          <input type="email" name="email" placeholder="your@email.com" required />
        </div>
        <div class="form-group">
          <label>Subject</label>
          <select name="subject">
            <option value="">Select enquiry type</option>
            <option>Package Enquiry</option>
            <option>Custom Package</option>
            <option>B2B Partnership</option>
            <option>Pricing & Quotation</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Message *</label>
          <textarea name="message" rows="5" placeholder="Tell us about your travel plans — destination, dates, group size, budget..." required></textarea>
        </div>
        <button type="submit" class="btn btn-ocean">🚀 Send Message</button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
