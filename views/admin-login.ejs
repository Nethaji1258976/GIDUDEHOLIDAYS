<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | GoDude Holidays</title>
  <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
<div class="admin-login-page">
  <div class="login-box">
    <img src="/images/logo.jpeg" alt="GoDude Holidays" />
    <h2>Admin Panel</h2>
    <p>Sign in to manage your travel business</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">❌ <%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login" style="display:flex;flex-direction:column;gap:16px;text-align:left;">
      <div>
        <label style="display:block;font-size:12px;font-weight:600;color:var(--gray);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Username</label>
        <input type="text" name="username" placeholder="Admin username" required
          style="width:100%;padding:13px 16px;border:1.5px solid rgba(10,61,98,0.12);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:12px;font-weight:600;color:var(--gray);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Password</label>
        <input type="password" name="password" placeholder="Admin password" required
          style="width:100%;padding:13px 16px;border:1.5px solid rgba(10,61,98,0.12);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;" />
      </div>
      <button type="submit" style="background:linear-gradient(135deg,#f0a500,#ff8c00);color:#1a1a2e;font-weight:700;font-size:15px;padding:14px;border:none;border-radius:10px;cursor:pointer;margin-top:8px;font-family:'DM Sans',sans-serif;">
        🔐 Sign In
      </button>
    </form>
    <p style="margin-top:24px;font-size:13px;color:var(--gray);">
      <a href="/" style="color:var(--ocean);text-decoration:none;">← Back to Website</a>
    </p>
  </div>
</div>
</body>
</html>
