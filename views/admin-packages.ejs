<%- include('partials/admin-sidebar', { pageTitle: 'Packages', activePage: 'packages' }) %>

<div class="admin-main">
  <div class="admin-topbar">
    <div class="topbar-title">
      <h2>✈ Manage Packages</h2>
      <p>Add, edit and delete travel packages</p>
    </div>
    <div class="topbar-right">
      <a href="/admin/packages/new" class="btn-sm btn-primary-sm">➕ Add New Package</a>
      <div class="admin-avatar">A</div>
    </div>
  </div>

  <div class="admin-content">
    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="alert alert-<%= msg.type==='success'?'success':'error' %>" style="margin-bottom:20px;"><%= msg.text %></div>
    <% } %>

    <div class="admin-card">
      <div class="card-header">
        <h3>All Packages (<%= packages ? packages.length : 0 %>)</h3>
      </div>
      <div style="overflow-x:auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Package Name</th>
              <th>Destination</th>
              <th>Duration</th>
              <th>Price</th>
              <th>Badge</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (packages && packages.length > 0) { %>
              <% packages.forEach(pkg => { %>
                <tr>
                  <td><strong><%= pkg.name %></strong></td>
                  <td><span class="badge badge-info"><%= pkg.destination %></span></td>
                  <td><%= pkg.duration %></td>
                  <td style="font-weight:700;color:var(--gold);">₹<%= pkg.price.toLocaleString('en-IN') %></td>
                  <td><% if(pkg.badge){ %><span class="badge badge-success"><%= pkg.badge %></span><% } %></td>
                  <td>
                    <div class="action-btns">
                      <a href="/admin/packages/edit/<%= pkg._id %>" class="btn-sm btn-info">✏️ Edit</a>
                      <form method="POST" action="/admin/packages/delete/<%= pkg._id %>" style="display:inline;"
                            onsubmit="return confirm('Delete this package?')">
                        <button type="submit" class="btn-sm btn-danger">🗑 Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" style="text-align:center;padding:48px;color:var(--gray);">
                No packages yet. <a href="/admin/packages/new" style="color:var(--gold);">Add your first package →</a>
              </td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script>setTimeout(()=>{const a=document.querySelector('.alert');if(a){a.style.transition='opacity 0.5s';a.style.opacity='0';setTimeout(()=>a.remove(),500);}},4000);</script>
</body></html>
