<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | GoDude Holidays' : 'GoDude Holidays — Explore the World' %></title>
  <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<nav class="navbar" id="navbar">
  <a href="/" class="nav-brand">
    <img src="/images/logo.jpeg" alt="GoDude Holidays" />
  </a>

  <ul class="nav-links" id="navLinks">
    <li><a href="/" class="<%= typeof activePage !== 'undefined' && activePage==='home' ? 'active' : '' %>">Home</a></li>
    <li><a href="/destinations" class="<%= typeof activePage !== 'undefined' && activePage==='destinations' ? 'active' : '' %>">Destinations</a></li>
    <li><a href="/services" class="<%= typeof activePage !== 'undefined' && activePage==='services' ? 'active' : '' %>">Services</a></li>
    <li><a href="/b2b" class="<%= typeof activePage !== 'undefined' && activePage==='b2b' ? 'active' : '' %>">B2B Partner</a></li>
    <li><a href="/about" class="<%= typeof activePage !== 'undefined' && activePage==='about' ? 'active' : '' %>">About</a></li>
    <li><a href="/contact" class="<%= typeof activePage !== 'undefined' && activePage==='contact' ? 'active' : '' %>">Contact</a></li>
    <% if (isLoggedIn) { %>
      <li><a href="/logout" class="nav-cta">Logout</a></li>
    <% } else { %>
      <li><a href="/login" class="nav-cta">Login</a></li>
    <% } %>
  </ul>

  <div class="hamburger" id="ham">
    <span></span><span></span><span></span>
  </div>
</nav>
