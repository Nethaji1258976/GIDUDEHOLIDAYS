<%- include('partials/header', { pageTitle: 'Destinations', activePage: 'destinations' }) %>

<div class="page-hero">
  <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1920&q=80');"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <div class="section-tag">Explore</div>
    <h1>Our Destinations</h1>
    <div class="breadcrumb"><a href="/">Home</a> › Destinations</div>
  </div>
</div>

<section class="section">
  <!-- Singapore -->
  <div id="singapore" style="margin-bottom:80px;">
    <div class="about-grid" style="max-width:1280px;margin:0 auto;">
      <div class="about-img-wrap reveal">
        <img src="https://images.unsplash.com/photo-1525625293386-3f8f99389edd?w=800&q=80" alt="Singapore" style="border-radius:16px;" />
      </div>
      <div class="reveal">
        <div class="section-tag">Southeast Asia</div>
        <h2 class="section-title"><span>Singapore</span></h2>
        <p class="section-sub">The Lion City — a dazzling blend of futuristic architecture, lush gardens, world-class food, and vibrant multicultural life.</p>
        <div class="package-grid" style="margin-top:24px;">
          <div class="pkg-card">
            <div class="pkg-img">
              <img src="https://images.unsplash.com/photo-1565967511849-76a60a516170?w=600&q=80" alt="Singapore Package" />
              <div class="pkg-badge">Popular</div>
            </div>
            <div class="pkg-body">
              <h4>Singapore Highlights — 5N/6D</h4>
              <p>Gardens by the Bay, Sentosa Island, Universal Studios, Marina Bay Sands, Orchard Road shopping.</p>
              <div class="pkg-meta"><span>📅 5 Nights</span><span>✈ Return Flights</span></div>
            </div>
            <div class="pkg-footer">
              <div class="pkg-price">₹45,000<small>per person (twin sharing)</small></div>
              <a href="/contact" class="btn btn-primary" style="padding:10px 20px;font-size:13px;">Enquire</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Malaysia -->
  <div id="malaysia" style="margin-bottom:80px;background:var(--gray-light);border-radius:24px;padding:60px;">
    <div class="section-header center reveal">
      <div class="section-tag">Southeast Asia</div>
      <h2 class="section-title"><span>Malaysia</span></h2>
      <p class="section-sub">Kuala Lumpur's iconic skyline, Cameron Highlands, Langkawi beaches, and the rich cultural tapestry of Penang.</p>
    </div>
    <div class="package-grid reveal">
      <div class="pkg-card">
        <div class="pkg-img"><img src="https://images.unsplash.com/photo-1596422846543-75c6fc197f07?w=600&q=80" alt="KL" /></div>
        <div class="pkg-body">
          <h4>Kuala Lumpur Explorer — 4N/5D</h4>
          <p>Petronas Towers, Batu Caves, KL Tower, Bukit Bintang, Genting Highlands.</p>
          <div class="pkg-meta"><span>📅 4 Nights</span><span>🏨 4-Star Hotels</span></div>
        </div>
        <div class="pkg-footer">
          <div class="pkg-price">₹32,000<small>per person</small></div>
          <a href="/contact" class="btn btn-primary" style="padding:10px 20px;font-size:13px;">Enquire</a>
        </div>
      </div>
      <div class="pkg-card">
        <div class="pkg-img"><img src="https://images.unsplash.com/photo-1559494507-9bbd768b56cb?w=600&q=80" alt="Langkawi" /></div>
        <div class="pkg-body">
          <h4>Langkawi Beach Escape — 5N/6D</h4>
          <p>Cable car, island hopping, Cenang Beach, duty-free shopping, mangrove tours.</p>
          <div class="pkg-meta"><span>📅 5 Nights</span><span>🏖 Beachfront</span></div>
        </div>
        <div class="pkg-footer">
          <div class="pkg-price">₹38,000<small>per person</small></div>
          <a href="/contact" class="btn btn-primary" style="padding:10px 20px;font-size:13px;">Enquire</a>
        </div>
      </div>
    </div>
  </div>

